<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" xsi="http://www.w3.org/2001/XMLSchema-instance" engine="UnityEngine.UIElements" editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:Label tabindex="-1" text="Score: 0" parse-escape-sequences="true" display-tooltip-when-elided="true" name="ScoreLabel" style="align-self: center; -unity-font-style: bold; font-size: 20px; top: 20px; color: rgb(47, 74, 202);" />
    <ui:Button text="Restart" parse-escape-sequences="true" display-tooltip-when-elided="true" name="RestartButton" style="position: absolute; top: 50%; left: auto; align-self: center; font-size: 20px; -unity-font-style: bold;" />
</ui:UXML>
